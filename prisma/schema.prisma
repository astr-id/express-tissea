generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model Category {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lines Line[]
}

model Line {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startTime String
  endTime   String
  category  Category @relation(fields: [categoryId], references: [id])
  categoryId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stops     LineStop[]
}

model Stop {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lineStops LineStop[]
}

model LineStop {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  line  Line   @relation(fields: [lineId], references: [id])
  lineId String
  stop  Stop   @relation(fields: [stopId], references: [id])
  stopId String
  order Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lineId, stopId])
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  username String
  email    String  @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
